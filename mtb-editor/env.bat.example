@echo off
rem Copy to env.bat (gitignored) to enable serve.py's remote tile fallback.
rem Create the token in the Cloudflare dashboard:
rem   Zero Trust -> Access -> Service Auth -> Service Tokens -> Create Service Token
rem Then add a "Service Auth" policy for that token on the dalarna-mtb.hammer-tour.com
rem Access application (alongside the existing email-login policy).

set CF_ACCESS_CLIENT_ID=
set CF_ACCESS_CLIENT_SECRET=

rem Optional override, defaults to https://dalarna-mtb.hammer-tour.com
rem set TILES_REMOTE_BASE=https://dalarna-mtb.hammer-tour.com
