# Copy to .env (gitignored) to enable serve.py's remote tile fallback.
# Create the token in the Cloudflare dashboard:
#   Zero Trust -> Access -> Service Auth -> Service Tokens -> Create Service Token
# Then add a "Service Auth" policy for that token on the dalarna-mtb.hammer-tour.com
# Access application (alongside the existing email-login policy).

export CF_ACCESS_CLIENT_ID=
export CF_ACCESS_CLIENT_SECRET=

# Optional override, defaults to https://dalarna-mtb.hammer-tour.com
# export TILES_REMOTE_BASE=https://dalarna-mtb.hammer-tour.com
